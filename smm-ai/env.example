OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase — Project Settings → API
# URL без /rest/v1/ в конце
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon public key (не путать с service_role и не подставлять URL REST API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Meta Ads — developers.facebook.com → App → Settings
# Пока App не создан: оставьте пустым — включится mock-провайдер автоматически
META_APP_ID=
META_APP_SECRET=
# META_USE_MOCK=true  — принудительный демо-режим (по умолчанию: mock если нет APP_ID)
# META_USE_MOCK=false — отключить mock даже без App (только OAuth)
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/meta/oauth/callback
META_GRAPH_API_VERSION=v21.0
